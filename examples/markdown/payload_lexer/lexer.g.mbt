///|
/// Step-based lexer (longest-match; declaration order breaks ties).
pub fn step_lex(source : String, pos : Int) -> @core.LexStep[Token] {
  let cursor = @core.LexCursor::new(source, pos)
  if cursor.is_done() {
    return Done
  }
  let view = cursor.view()
  let mut best_len = 0
  let mut best : Token? = None
  match re"^(?:(#{1,6})([ \t]))".execute(view) {
    Some(m) => {
      let len = m.content().length()
      if len > best_len {
        best_len = len
        best = Some(HeadingMarker(m.group(1).unwrap_or("").length()))
      }
    }
    None => ()
  }
  match re"^(?:(`{3,})([^\r\n]*))".execute(view) {
    Some(m) => {
      let len = m.content().length()
      if len > best_len {
        best_len = len
        best = Some(
          CodeFenceOpen(
            m.group(1).unwrap_or("").length(),
            m.group(2).unwrap_or("").to_owned(),
          ),
        )
      }
    }
    None => ()
  }
  match best {
    None =>
      @core.LexStep::Invalid(
        at=pos,
        width=@core.next_char_offset(source, pos) - pos,
        message="Unexpected character",
      )
    Some(tok) => {
      cursor.advance_code_units(best_len)
      cursor.produced(tok)
    }
  }
}
