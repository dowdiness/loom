///|
/// Step-based lexer (longest-match; declaration order breaks ties).
pub fn step_lex(source : String, pos : Int) -> @core.LexStep[Token] {
  let cursor = @core.LexCursor::new(source, pos)
  if cursor.is_done() {
    return Done
  }
  let view = cursor.view()
  let mut best_len = 0
  let mut best : Token? = None
  let mut best_ident = false
  if cursor.starts_with("-") && 1 > best_len {
    best_len = 1
    best = Some(Minus)
    best_ident = false
  }
  if cursor.starts_with("->") && 2 > best_len {
    best_len = 2
    best = Some(Arrow)
    best_ident = false
  }
  if view =~ (re"^(?:[a-zA-Z_][a-zA-Z0-9_]*)" as m) {
    let len = m.length()
    if len > best_len {
      best_len = len
      best = Some(Ident)
      best_ident = true
    }
  }
  if view =~ (re"^(?:[0-9]+)" as m) {
    let len = m.length()
    if len > best_len {
      best_len = len
      best = Some(Number)
      best_ident = false
    }
  }
  if view =~ (re"^(?:[ \t\r\n]+)" as m) {
    let len = m.length()
    if len > best_len {
      best_len = len
      best = Some(Whitespace)
      best_ident = false
    }
  }
  match best {
    None =>
      @core.LexStep::Invalid(
        at=pos,
        width=@core.next_char_offset(source, pos) - pos,
        message="Unexpected character",
      )
    Some(tok) => {
      cursor.advance_code_units(best_len)
      let final_tok = if best_ident {
        match source[pos:pos + best_len].to_owned() {
          "let" => Let
          _ => tok
        }
      } else {
        tok
      }
      cursor.produced(final_tok)
    }
  }
}
