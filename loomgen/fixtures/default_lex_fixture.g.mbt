///|
/// Step-based lexer (longest-match; declaration order breaks ties).
pub fn step_lex(source : String, pos : Int) -> @core.LexStep[Token] {
  let cursor = @core.LexCursor::new(source, pos)
  if cursor.is_done() {
    return Done
  }
  let view = cursor.view()
  let mut best_len = 0
  let mut best : Token? = None
  if view =~ (re"^(?:[a-zA-Z_][a-zA-Z0-9_]*)", after=rest) {
    let len = view.length() - rest.length()
    if len > best_len {
      best_len = len
      best = Some(Ident)
    }
  }
  if view =~ (re"^(?:[0-9]+(\.[0-9]+)?)", after=rest) {
    let len = view.length() - rest.length()
    if len > best_len {
      best_len = len
      best = Some(Number)
    }
  }
  if view =~ (re"^(?:[ \t\r\n]+)", after=rest) {
    let len = view.length() - rest.length()
    if len > best_len {
      best_len = len
      best = Some(Whitespace)
    }
  }
  match best {
    None =>
      @core.LexStep::Invalid(
        at=pos,
        width=@core.next_char_offset(source, pos) - pos,
        message="Unexpected character",
      )
    Some(tok) => {
      cursor.advance_code_units(best_len)
      cursor.produced(tok)
    }
  }
}
