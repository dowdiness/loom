import {
  "dowdiness/loom/core",
  "dowdiness/seam",
  "moonbitlang/core/debug",
}

import {
  "moonbitlang/core/quickcheck" @coreqc,
  "moonbitlang/core/quickcheck/splitmix",
  "moonbitlang/quickcheck" @qc,
} for "wbtest"

// QuickCheck Shrink implementations intentionally exist only for property
// tests; suppress their unused-value/unused-variable warnings for vendored
// consumers that promote warnings to errors.
warnings = "-1-2"
